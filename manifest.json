{
  "manifest_version": 3,
  "name": "Digg for X",
  "version": "0.1.0",
  "description": "Digg-powered enrichment for X.com — sidebar feed, profile classifications, vibe & topic distributions, gravity scores, and inline badges.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://digg.com/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "css": ["content/inject.css"],
      "js": ["lib/icons.js", "content/inject.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["ui/panel.html", "ui/panel.js", "ui/panel.css", "lib/icons.js"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ],
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Digg for X",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
